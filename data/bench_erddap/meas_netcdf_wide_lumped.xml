<dataset type="EDDTableFromNcCFFiles" datasetID="meas_netcdf_wide_lumped" active="true">
  <reloadEveryNMinutes>10080</reloadEveryNMinutes>
  <updateEveryNMillis>0</updateEveryNMillis>
  <fileDir>/share/data/erddap-duckdb/serving/wide_lumped_netcdf/ctd_measurement/</fileDir>
  <fileNameRegex>.*\.nc</fileNameRegex>
  <recursive>true</recursive>
  <pathRegex>.*</pathRegex>
  <metadataFrom>last</metadataFrom>
  <standardizeWhat>0</standardizeWhat>
  <accessibleViaFiles>true</accessibleViaFiles>
  <addAttributes>
    <att name="cdm_data_type">Profile</att>
    <att name="featureType">Profile</att>
    <att name="cdm_profile_variables">profile_id, time, latitude, longitude, cruise_key, line, sta</att>
    <att name="subsetVariables">cruise_key, line, sta</att>
    <att name="Conventions">CF-1.6, COARDS, ACDD-1.3</att>
    <att name="institution">CalCOFI</att>
    <att name="infoUrl">https://calcofi.org</att>
    <att name="sourceUrl">(local files)</att>
    <att name="license">CC-BY 4.0</att>
    <att name="creator_name">CalCOFI</att>
    <att name="creator_url">https://calcofi.org</att>
    <att name="title">CalCOFI CTD full wide NetCDF lumped</att>
    <att name="summary">Single-file CF profile NetCDF (lumped).</att>
    <att name="standard_name_vocabulary">CF Standard Name Table v79</att>
  </addAttributes>
<dataVariable>
    <sourceName>profile_id</sourceName>
    <destinationName>profile_id</destinationName>
    <dataType>String</dataType>
    <addAttributes>
      <att name="cf_role">profile_id</att>
      <att name="ioos_category">Identifier</att>
      <att name="long_name">Profile id</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>time</sourceName>
    <destinationName>time</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="units">seconds since 1970-01-01T00:00:00Z</att>
      <att name="ioos_category">Time</att>
      <att name="standard_name">time</att>
      <att name="long_name">Time</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>latitude</sourceName>
    <destinationName>latitude</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="units">degrees_north</att>
      <att name="ioos_category">Location</att>
      <att name="standard_name">latitude</att>
      <att name="long_name">Latitude</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>longitude</sourceName>
    <destinationName>longitude</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="units">degrees_east</att>
      <att name="ioos_category">Location</att>
      <att name="standard_name">longitude</att>
      <att name="long_name">Longitude</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>cruise_key</sourceName>
    <destinationName>cruise_key</destinationName>
    <dataType>String</dataType>
    <addAttributes>
      <att name="ioos_category">Identifier</att>
      <att name="long_name">Cruise key</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>line</sourceName>
    <destinationName>line</destinationName>
    <dataType>String</dataType>
    <addAttributes>
      <att name="ioos_category">Location</att>
      <att name="long_name">Line</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>sta</sourceName>
    <destinationName>sta</destinationName>
    <dataType>String</dataType>
    <addAttributes>
      <att name="ioos_category">Other</att>
      <att name="long_name">Sta</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>depth</sourceName>
    <destinationName>depth</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="units">m</att>
      <att name="positive">down</att>
      <att name="ioos_category">Location</att>
      <att name="standard_name">depth</att>
      <att name="long_name">Depth</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>temperature_ave</sourceName>
    <destinationName>temperature_ave</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="ioos_category">Temperature</att>
      <att name="long_name">Average temperature</att>
      <att name="units">degC</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>salinity_ave_corr</sourceName>
    <destinationName>salinity_ave_corr</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="ioos_category">Salinity</att>
      <att name="long_name">Average salinity corrected</att>
      <att name="units">PSU</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>oxygen_ml_l_ave_sta_corr</sourceName>
    <destinationName>oxygen_ml_l_ave_sta_corr</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="ioos_category">Dissolved O2</att>
      <att name="long_name">DO average station-corrected</att>
      <att name="units">ml/L</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>fluorescence_v</sourceName>
    <destinationName>fluorescence_v</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="ioos_category">Other</att>
      <att name="long_name">Fluorescence voltage</att>
      <att name="units">V</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>isus_v</sourceName>
    <destinationName>isus_v</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="ioos_category">Other</att>
      <att name="long_name">ISUS nitrate voltage</att>
      <att name="units">V</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>sigma_theta_1</sourceName>
    <destinationName>sigma_theta_1</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="ioos_category">Other</att>
      <att name="long_name">Potential density sensor 1</att>
      <att name="units">kg/m3</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>dynamic_height</sourceName>
    <destinationName>dynamic_height</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="ioos_category">Other</att>
      <att name="long_name">Dynamic height</att>
      <att name="units">dyn m</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>specific_volume_anomaly</sourceName>
    <destinationName>specific_volume_anomaly</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="ioos_category">Other</att>
      <att name="long_name">Specific volume anomaly</att>
      <att name="units">10^-8 m3/kg</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>par</sourceName>
    <destinationName>par</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="ioos_category">Other</att>
      <att name="long_name">Photosynthetically active radiation</att>
      <att name="units">uE/m2/s</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>spar</sourceName>
    <destinationName>spar</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="ioos_category">Other</att>
      <att name="long_name">Surface PAR</att>
      <att name="units">uE/m2/s</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>beam_attenuation</sourceName>
    <destinationName>beam_attenuation</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="ioos_category">Other</att>
      <att name="long_name">Beam attenuation coefficient</att>
      <att name="units">1/m</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>transmissometer</sourceName>
    <destinationName>transmissometer</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="ioos_category">Other</att>
      <att name="long_name">Light transmissometer</att>
      <att name="units">%</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>ph</sourceName>
    <destinationName>ph</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="ioos_category">Other</att>
      <att name="long_name">pH</att>
      <att name="units">pH</att>
    </addAttributes>
  </dataVariable>
<dataVariable>
    <sourceName>pressure</sourceName>
    <destinationName>pressure</destinationName>
    <dataType>double</dataType>
    <addAttributes>
      <att name="ioos_category">Other</att>
      <att name="long_name">Pressure</att>
      <att name="units">dbar</att>
    </addAttributes>
  </dataVariable>
</dataset>
